[flake8]
max-line-length = 120
extend-ignore =
    # E221: multiple spaces before operator (kita pakai alignment)
    E221,
    # E203: whitespace before ':' (biasa di dict/slice)
    E203,
    # W503: line break before binary operator
    W503
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    venv,
    .venv,
    instance
